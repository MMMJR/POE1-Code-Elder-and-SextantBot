                                            <CheckBox Content="Use Aspect of the Spider" Margin="10,0,10,0" IsChecked="{Binding Path=EnableAspectsOfTheSpider, Mode=TwoWay}" VerticalAlignment="Center" ToolTip="Should use Aspect of the Spider"></CheckBox>
                                        </StackPanel>

                                    </GroupBox>

