                                                    <DataTemplate>
                                                        <Button Click="RemoveDefensiveSkillRule" VerticalAlignment="Center">X</Button>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </ScrollViewer>
